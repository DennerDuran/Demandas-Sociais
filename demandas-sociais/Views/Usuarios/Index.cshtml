@model IEnumerable<demandas_sociais.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<h1>Lista de Usuários</h1>

<p>
  <a asp-action="Create" class="btn btn-primary" style="background-color: purple; border-color: purple; color: white">Adicionar novo Usuário</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Perfil)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(model => item.Perfil)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: purple; color: purple">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: purple; color: purple">Visualizar</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: red; color: red">Deletar</a>
            </td>
        </tr>
}
    </tbody>
</table>
