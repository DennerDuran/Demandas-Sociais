@model demandas_sociais.Models.Usuario

@{
    ViewData["Title"] = "Deletar Dados";
}

<h1>Deletar dados de Usuário</h1>

<h3>Tem certeza que deseja remover este usuário?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Perfil)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Perfil)
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" style="background-color: white; border-color: purple; color: purple;" class="btn btn-primary">Voltar</a> |
        <input type="submit" value="Deletar" class="btn btn-danger" />
    </form>
</div>
