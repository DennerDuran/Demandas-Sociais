@model demandas_sociais.Models.Demandas

@{
    ViewData["Title"] = "Delete";
}

<h1>Remover uma Demanda</h1>

<h3>Tem certeza que deseja remover esta demanda?</h3>
<div>
    <h4>Dados da Demanda</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Demanda)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Demanda)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="id" />
        <a asp-action="Index" style="background-color: white; border-color: purple; color: purple;" class="btn btn-primary">Voltar</a> |
        <input type="submit" value="Deletar" class="btn btn-danger"/>
       
    </form>
</div>
