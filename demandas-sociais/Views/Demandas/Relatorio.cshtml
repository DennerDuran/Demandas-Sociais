@model IEnumerable<demandas_sociais.Models.Recursos>

@{
    ViewData["Title"] = "Relatorio";
}

<h1>Relatório da Demanda: @ViewBag.Demandas.Demanda</h1>

<h3> Custo Total: @ViewBag.Total</h3>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Descricao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Custo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tipo)
            </th>

            <th></th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => item.Descricao)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Data)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Custo)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Quantidade)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Tipo)
                </td>
            </tr>
        }
    </tbody>
</table>

