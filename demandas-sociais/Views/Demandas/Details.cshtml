@model demandas_sociais.Models.Demandas

@{
    ViewData["Title"] = "Details";
}

<h1>Detalhes da Demanda</h1>

<div>
    <h4>Demandas</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Demanda)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Demanda)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-info" style="background-color: white; border-color: purple; color: purple ">Voltar</a> |
    <a asp-action="Edit" class="btn btn-warning" style="background-color: purple; border-color: white; color: white " asp-route-id="@Model?.id">Editar</a> 
</div>
