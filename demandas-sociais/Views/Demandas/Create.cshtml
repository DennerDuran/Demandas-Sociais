@model demandas_sociais.Models.Demandas

@{
    ViewData["Title"] = "Create";
}

<div class="container-fluid mt-4">
<!-- Inicio-->

    <div class="mb-4">
    <h1 class="mb-1">Cadastrar Demanda</h1>
    <small class="text-muted">Data: @DateTime.Now.ToString("dd/MM/yyyy")</small>
    </div>

    <!-- ETAPAS (LADO ESQUERDO) -->
    <div class="create-layout">

        <div class="etapas">
            <div class="etapa ativa">Identificação</div>
            <div class="etapa">Detalhes e Evidências</div>
            <div class="etapa">Localização</div>
        </div>

    <!-- Etapa 01 - Identificação -->
  
    <div class="col-lg-8">
        <div class="card p-4 shadow-sm">

       <!-- FORMULÁRIO (CARD PRINCIPAL) -->
        <form asp-action="Create">
                <div class="step step-1 active"> 

            <!-- Campo buscar morador -->
         <div class="form-group mt-3">
           <input type="text"
           class="form-control"
           placeholder="Buscar Morador (por Nome, RG ou CPF)">
         </div>
         
                    <!-- campo tipo de necessidade morador -->
                    <div class="bg-urgencia mt-4">
                        <label class="control-label">Tipo de Necessidade</label>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <div class="form-check"><input type="checkbox"> Saúde</div>
                                <div class="form-check"><input type="checkbox"> Alimentação/Hidratação</div>
                                <div class="form-check"><input type="checkbox"> Vestuário</div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check"><input type="checkbox"> Apoio Jurídico</div>
                                <div class="form-check"><input type="checkbox"> Emprego</div>
                            </div>
                        </div>
                    </div>


                <!-- Nível de Urgência -->
                <div class="bg-urgencia mt-4">
                    <label class="control-label">Nível de Urgência</label>

                    <!-- Prioridade -->
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Prioridade" value="1">
                        <label class="form-check-label">Baixa (Pode aguardar planejamento regular)</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Prioridade" value="2">
                        <label class="form-check-label">Média (Necessita atenção nos próximos dias)</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Prioridade" value="3">
                        <label class="form-check-label">Alta (Risco à vida ou integridade física imediata)</label>
                    </div>
                </div>
                <span asp-validation-for="Prioridade" class="text-danger"></span>

            <!-- Campos de Adicionar/Voltar -->
                    <!-- <a asp-action="Index" class="btn btn-primary" style="background-color: white; border-color: purple; color: purple">Voltar</a>-->

                    <button type="button"
                            class="btn btn-primary"
                            onclick="nextStep(2)">
                        Avançar
                    </button>
                </div>
                    <!-- fim do step 01-->

      <!-- Inicio do Card 02 - Detalhes e Evidências -->

                <div class="step step-2">

                <h5>Detalhes e Evidências</h5>

                    <!-- N da Demanda -->
                    <div class="form-group mt-4">
                        <label asp-for="Demanda" class="control-label"></label>
                        <input asp-for="Demanda" class="form-control" />
                        <span asp-validation-for="Demanda" class="text-danger"></span>
                    </div>


                    <!-- Descrição da Demanda -->
                    <div class="form-group mt-4">
                        <label asp-for="Nome" class="control-label"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <!-- Tipo de Demanda -->
                    <div class="form-group mt-4">
                        <label asp-for="Tipo" class="control-label"></label>
                        <input asp-for="Tipo" class="form-control" />
                        <span asp-validation-for="Tipo" class="text-danger"></span>
                    </div>

            <!-- Inicio do Card 02 - Detalhes e Evidências -->
                <div class="d-flex justify-content-between mt-4">
                    <button type="button"
                            class="btn btn-outline-primary"
                            onclick="nextStep(1)">
                        Voltar
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            onclick="nextStep(3)">
                        Avançar
                    </button>
                </div>

            </div>
                <!-- fim do Card 02-->


                <!-- Inicio do Card 03 - Localização -->
                <div class="step step-3"> 

                    <h5>Localização</h5>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button"
                                class="btn btn-outline-primary"
                                onclick="nextStep(2)">
                            Voltar
                        </button>
                        <input type="submit" value="Adicionar" class="btn btn-primary" style="background-color: #6f42c1; border-color: #6f42c1;" />
                </div>
                </div>
                <!-- fim do Card 03-->
            </form>
            </div>
        </div>
    </div>    
</div>
 
    <script>
        function nextStep(step) {

            // Esconde todos os cards
            document.querySelectorAll('.step').forEach(s => {
                s.classList.remove('active');
            });

            // Mostra o card correto
            document.querySelector('.step-' + step).classList.add('active');

            // Atualiza o menu lateral
            document.querySelectorAll('.etapa').forEach(e => {
                e.classList.remove('ativa');
            });

            // card 1 = primeira etapa, etc.
            const etapaAtual = document.querySelector('.etapas .etapa:nth-child(' + step + ')');
            if (etapaAtual) {
                etapaAtual.classList.add('ativa');
            }
        }
    </script>
