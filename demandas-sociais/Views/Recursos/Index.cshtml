@model IEnumerable<demandas_sociais.Models.Recursos>

@{
    ViewData["Title"] = "Index";
}

<h1>Recursos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary" style="background-color: purple; border-color: purple; color: white">Cadastrar novo Recurso</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Descricao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Custo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tipo)
            </th>
       
            <th></th>
        </tr>
    </thead>
    <tbody>

@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Descricao)
            </td>
            <td>
                @Html.DisplayFor(model => item.Data)
            </td>
            <td>
                @Html.DisplayFor(model => item.Custo)
            </td>
            <td>
                @Html.DisplayFor(model => item.Quantidade)
            </td>
            <td>
                @Html.DisplayFor(model => item.Tipo)
            </td>
         
           
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: purple; color: purple">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: purple; color: purple">Visualizar</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-primary" style="background-color: white; border-color: red; color: red">Deletar</a>
            </td>
        </tr>
}
    </tbody>
</table>
